# Azure Speech リソース（カスタムドメインのエンドポイント。キーレスにはカスタムドメイン名が必須）
SPEECH_ENDPOINT=https://<resource-name>.cognitiveservices.azure.com/
SPEECH_REGION=japaneast
# TTS のキーレス（aad#{resourceId}#{token}）に必要なリソースID
SPEECH_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<resource-name>

# LLM 処理用（Foundry プロジェクト＋チャットモデル）
PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
MODEL_DEPLOYMENT=gpt-5-mini

# 音声入出力
INPUT_WAV=input.wav
TTS_VOICE=ja-JP-NanamiNeural
