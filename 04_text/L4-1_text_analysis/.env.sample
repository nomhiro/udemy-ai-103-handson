# Microsoft Foundry プロジェクトのエンドポイント（生成プロンプト版 main.py 用）
PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
# デプロイ済みチャットモデルのデプロイ名（構造化出力対応モデル）
MODEL_DEPLOYMENT=gpt-5-mini

# 比較版 language_sdk_compare.py を使う場合のみ（Azure Language エンドポイント）
AZURE_LANGUAGE_ENDPOINT=https://<resource-name>.cognitiveservices.azure.com/
