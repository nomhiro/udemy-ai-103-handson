# Microsoft Foundry プロジェクトのエンドポイント
# ポータル(https://ai.azure.com) のプロジェクト右上「エンドポイント」から取得
# 形式: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=

# 比較する2モデルのデプロイ名（Foundry でデプロイ済みのもの。カタログ名ではなくデプロイ名）
MODEL_LARGE=gpt-5.4
MODEL_SMALL=gpt-5.4-nano

# 認証はキーレス（az login 済みの資格情報を DefaultAzureCredential が使用）。APIキーは不要。
