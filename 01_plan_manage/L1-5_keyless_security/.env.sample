# L1-5 実践: キーレス化（DefaultAzureCredential ＋ ロール割り当て）
# このファイルを .env にコピーして値を埋める (.env はコミットしない)

# --- main.py 用 (Foundry プロジェクト / キーレス) ---
PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
MODEL_DEPLOYMENT=gpt-4.1

# --- keyless_openai_direct.py 用 (Foundry Models リソースエンドポイント) ---
# 末尾は /openai/v1/ まで。<resource>.openai.azure.com でも .services.ai.azure.com でも可
FOUNDRY_OPENAI_BASE_URL=https://<resource-name>.openai.azure.com/openai/v1/

# 比較用(任意): APIキー。キーレス運用では設定しなくてよい。
# disableLocalAuth を有効化した後にキー方式が 401 になることを確認したい場合のみ設定する。
FOUNDRY_API_KEY=
