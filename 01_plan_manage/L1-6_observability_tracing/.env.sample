# L1-6 実践: アプリにトレースを仕込み Application Insights で可視化
# このファイルを .env にコピーして値を埋める (.env はコミットしない)

# --- Foundry プロジェクト (キーレス)。Overview ページのエンドポイント ---
PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
MODEL_DEPLOYMENT=gpt-4.1

# --- (任意) トレース計測の挙動を上書きしたいとき。コード側に既定があるので通常は不要 ---
# GenAI トレース計測の実験フラグ (既定 true)
# AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=true
# メッセージ本文を span に記録 (PII を含みうる。開発時のみ true、本番は false)
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
