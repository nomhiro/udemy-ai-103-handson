# L1-4 実践: クォータ確認 + リトライ + コストタグ
# このファイルを .env にコピーして値を埋める (.env はコミットしない)

# --- retry_demo.py 用 (Foundry プロジェクト / キーレス) ---
PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
MODEL_DEPLOYMENT=gpt-4.1

# --- check_quota.py 用 (ARM REST / Usages・Model Capacities API) ---
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
QUOTA_LOCATION=eastus

# Model Capacities API 用 (任意。デプロイ可能な空き容量を調べたいモデル)
MODEL_NAME=gpt-4o
MODEL_VERSION=2024-08-06
MODEL_FORMAT=OpenAI
