# L1-3 実践: Bicep（IaC）で Foundry リソース＋プロジェクト＋モデルデプロイを一括作成する（PowerShell）。
#
# 同じ main.bicep を dev/stg/prod でパラメータだけ替えて適用すれば、環境差分を最小化できる。
# 実行方法: PowerShell で1コマンドずつ実行。継続行は行末のバッククォート ` で表す。
#
# 事前に `az login` 済み、かつ Bicep CLI が利用可能（az に同梱）であること。

$RG = "ai103-l1-3-rg"
$LOCATION = "eastus2"

# 1) リソースグループ
az group create --name $RG --location $LOCATION

# 2) what-if（変更プレビュー）: 実際に何が作られる/変わるかを事前確認（CI/CD の PR 相当）
az deployment group what-if `
  --resource-group $RG `
  --template-file main.bicep `
  --parameters foundryName=ai103l13foundry projectName=ai103-l13-proj `
               deploymentName=chat modelName=gpt-5.4-nano modelVersion=2026-03-17

# 3) 適用（apply）: 問題なければ実際にデプロイ
az deployment group create `
  --resource-group $RG `
  --template-file main.bicep `
  --parameters foundryName=ai103l13foundry projectName=ai103-l13-proj `
               deploymentName=chat modelName=gpt-5.4-nano modelVersion=2026-03-17

# 4) 出力（エンドポイント・デプロイ名）を確認 → .env に転記
az deployment group show `
  --resource-group $RG `
  --name main `
  | jq '.properties.outputs'

# 5) 作成されたリソース一覧
az resource list --resource-group $RG -o table
