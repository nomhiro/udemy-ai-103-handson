# Microsoft Foundry プロジェクトのエンドポイント
# 形式: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>

# vision 対応チャットモデルの「デプロイ名」(例: gpt-4o)
# 画像理解に対応するモデル(GPT-4o系/GPT-4.1系/GPT-5系/o系 など)をデプロイして指定。
VISION_MODEL=gpt-4o
