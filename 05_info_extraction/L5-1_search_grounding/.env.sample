# Azure AI Search
SEARCH_ENDPOINT=https://<your-search>.search.windows.net
SEARCH_INDEX_NAME=l5-1-grounding

# サンプル文書を置いた Blob コンテナ（マネージドID読み取り／キーレス）
# ResourceId 形式にすると、検索サービスのマネージドIDで Blob を読む（事前に Storage Blob Data Reader を付与）
BLOB_CONNECTION_STRING=ResourceId=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Storage/storageAccounts/<account>;
BLOB_CONTAINER=l5-1-docs

# Azure OpenAI（埋め込み）
AOAI_ENDPOINT=https://<your-aoai>.openai.azure.com
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AOAI_EMBEDDING_DIMENSIONS=3072

# Foundry プロジェクト（エージェント）
PROJECT_ENDPOINT=https://<resource>.ai.azure.com/api/projects/<project>
MODEL_DEPLOYMENT=gpt-4.1-mini
# Foundry ポータルで作成した Azure AI Search への接続名
SEARCH_CONNECTION_NAME=my-search-connection
